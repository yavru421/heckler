@using Heckler.Frontend.Models
@inject JokeService JokeService

<div class="stage-container">
    <div class="stage-header">
        <h2>Stage Spotlight</h2>
        <div class="live-indicator"></div>
    </div>
    
    <div class="joke-actions">
        <button class="btn-primary" @onclick="GenerateJoke" disabled="@isGenerating">
            @(isGenerating ? "Cooking up some spice... 🌶️" : "Get a New Joke 🎤")
        </button>
    </div>

    <div class="joke-feed single-spotlight">
        @if (LiveJokes == null)
        {
            <p class="loading-text">Tuning the mic... 🎤</p>
        }
        else
        {
            var unratedJokes = LiveJokes.Where(j => !RatedJokeIds.Contains(j.Id)).ToList();

            @if (unratedJokes.Count == 0)
            {
                <div class="empty-card glass-panel">
                    <p class="empty-text">The stage is empty. Hit the button to get roasted by the AI.</p>
                </div>
            }
            else
            {
                // Only show the single, most recent unrated joke on stage
                var activeJoke = unratedJokes.First();
                <JokeCard @key="activeJoke.Id" Joke="activeJoke" OnVoted="() => HandleVote(activeJoke.Id)" />
            }
        }
    </div>
</div>

@code {
    private List<JokeModel>? LiveJokes { get; set; }
    private HashSet<string> RatedJokeIds { get; set; } = new();
    private bool isGenerating = false;

    protected override async Task OnInitializedAsync()
    {
        await LoadJokes();
    }

    private async Task LoadJokes()
    {
        LiveJokes = await JokeService.GetActiveJokesAsync();
        StateHasChanged();
    }

    private async Task HandleVote(string jokeId)
    {
        RatedJokeIds.Add(jokeId);
        await LoadJokes();
    }

    private async Task GenerateJoke()
    {
        isGenerating = true;
        StateHasChanged();
        
        await JokeService.GenerateJokeAsync();
        await LoadJokes();
        
        isGenerating = false;
        StateHasChanged();
    }
}

