@using Heckler.Frontend.Models
@inject JokeService JokeService

<div class="joke-card glass-panel">
    <div class="joke-content">
        <p class="joke-text">"@Joke.Text"</p>
        <div class="joke-stats">
            <span class="stat kill">🔥 @Joke.Kills Kills</span>
            <span class="stat bomb">🍅 @Joke.Bombs Bombs</span>
            <span class="stat weight">📊 Weight: @Joke.ProbabilityWeight.ToString("F2")</span>
        </div>
        <span class="joke-meta">Generated from premise: @Joke.Premise</span>
    </div>
    
    <div class="heckle-controls">
        <button class="btn-heckle kill" @onclick="OnKill">
            🔥 KILL
        </button>
        <button class="btn-heckle bomb" @onclick="OnBomb">
            🍅 BOMB
        </button>
    </div>
</div>

@code {
    [Parameter] public JokeModel Joke { get; set; } = new();
    [Parameter] public EventCallback OnVoted { get; set; }

    private async Task OnKill()
    {
        await JokeService.RateJokeAsync(Joke.Id, "kill");
        await OnVoted.InvokeAsync();
    }

    private async Task OnBomb()
    {
        await JokeService.RateJokeAsync(Joke.Id, "bomb");
        await OnVoted.InvokeAsync();
    }
}

