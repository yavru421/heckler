@page "/"
@inject NavigationManager Nav

<div class="heckler-app">
    <main class="app-content" style="display: flex; flex-direction: column; align-items: center; justify-content: center; min-height: 80vh; padding: 2rem 1rem;">
        <div class="fade-in-text" style="text-align: center;">
            <h1 style="font-size: 4rem; margin-bottom: 0; letter-spacing: 6px; font-family: 'Oswald', sans-serif;">HECKL<span class="neon-text">ER</span></h1>
            <div style="color: var(--neon-green); text-transform: uppercase; letter-spacing: 3px; font-size: 0.8rem; margin-top: 0.5rem; font-weight: 600;">🎟️ Crowd-Sourced Comedy</div>
            
            <p style="color: var(--text-secondary); margin: 2rem auto; font-size: 1.1rem; max-width: 450px; line-height: 1.7;">
                Post jokes. Heckle others. Vote ruthlessly. The crowd decides who's funny.
            </p>

            <div style="display: flex; flex-direction: column; gap: 1rem; width: 100%; max-width: 400px; margin: 2rem auto;">
                <button id="btn-browse-feed" class="btn-generate haptic-btn" @onclick='() => Nav.NavigateTo("/feed")' style="padding: 1.4rem; font-size: 1.2rem; background: linear-gradient(135deg, var(--neon-purple), var(--neon-blue)); box-shadow: 0 4px 20px rgba(0, 240, 255, 0.3);">
                    📜 BROWSE THE FEED
                </button>
                <button id="btn-take-stage" class="btn-generate haptic-btn" @onclick='() => Nav.NavigateTo("/submit")' style="padding: 1.4rem; font-size: 1.2rem; background: linear-gradient(135deg, var(--neon-red), var(--neon-purple)); box-shadow: 0 4px 20px rgba(255, 51, 102, 0.3);">
                    🎤 TAKE THE STAGE
                </button>
                <div style="display: flex; gap: 1rem;">
                    <button id="btn-wall-shame" class="btn-generate haptic-btn" @onclick='() => Nav.NavigateTo("/shame")' style="flex: 1; padding: 1rem; font-size: 0.95rem; background: rgba(255,255,255,0.05); border: 1px solid rgba(255,255,255,0.1); color: var(--neon-red);">
                        💀 Wall of Shame
                    </button>
                    <button id="btn-hall-fame" class="btn-generate haptic-btn" @onclick='() => Nav.NavigateTo("/fame")' style="flex: 1; padding: 1rem; font-size: 0.95rem; background: rgba(255,255,255,0.05); border: 1px solid rgba(255,255,255,0.1); color: var(--neon-green);">
                        🏆 Hall of Fame
                    </button>
                </div>
            </div>
        </div>
    </main>
</div>
