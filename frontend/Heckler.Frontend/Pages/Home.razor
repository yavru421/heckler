@page "/"
@inject NavigationManager NavigationManager
@inject IJSRuntime JSRuntime

<div class="heckler-app">
    <header class="app-header glass-panel">
        <div class="logo">
            <h1>HECKL<span class="neon-text">ER</span></h1>
            <div class="age-warning" style="color: var(--neon-green); text-transform: uppercase; letter-spacing: 2px; font-size: 0.8rem; margin-top: -10px; margin-bottom: 20px;">🎟️ UNCENSORED COMEDY (MATURE AUDIENCES)</div>
        </div>
    </header>

    <main class="app-content" style="display: flex; flex-direction: column; align-items: center; justify-content: center; min-height: 50vh;">
        @if (!enteredClub)
        {
            <div class="enter-club-container">
                <button class="btn-generate" style="font-size: 2rem; padding: 2rem 4rem;" @onclick="EnterClub">Enter the Club 🎤</button>
            </div>
        }
        else
        {
            <div class="main-menu glass-panel" style="padding: 2rem; text-align: center; display: flex; flex-direction: column; gap: 1.5rem; width: 100%; max-width: 500px;">
                <h2>Choose Your Stage</h2>
                <div class="menu-options" style="display: flex; flex-direction: column; gap: 1rem;">
                    <button class="btn-generate" @onclick='() => NavigateTo("/writers")'>
                        📝 Writers Room (Read & Rate)
                    </button>
                    <button class="btn-generate" @onclick='() => NavigateTo("/live")'>
                        🎙️ Live Show (Audio First)
                    </button>
                </div>
            </div>
        }
    </main>
</div>

<!-- Hidden audio element for the laugh track -->
<audio id="laugh-audio" src="/assets/laugh.mp3" preload="auto"></audio>

@code {
    private bool enteredClub = false;

    private async Task EnterClub()
    {
        enteredClub = true;
        try
        {
            await JSRuntime.InvokeVoidAsync("eval", "document.getElementById('laugh-audio').play().catch(() => {})");
        }
        catch
        {
            // Ignore if JS interop fails
        }
    }

    private void NavigateTo(string path)
    {
        NavigationManager.NavigateTo(path);
    }
}
