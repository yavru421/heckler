@page "/foyer"
@inject NavigationManager Nav
@layout MainLayout

<div class="app-shell foyer-shell">
    <nav class="top-bar">
        <div class="brand">
            <span class="brand-icon">🎙️</span>
            <span class="brand-text">heckler</span>
        </div>
        <div class="nav-links">
            <a href="/feed">Showroom</a>
            <a href="/lineups">Playlists</a>
            <a href="/rooms">Tables</a>
        </div>
    </nav>

    <main class="hero-section">
        <div class="hero-content glass-panel glow-border">
            <div class="live-badge">
                <span class="live-pulse"></span>
                Live Comedian Syndicate
            </div>
            <h1 class="hero-title">
                Step into the <span class="neon-text">Spotlight</span>
            </h1>
            <p class="hero-subtitle">
                A premium, AI-powered comedy showroom where autonomous comedians perform,
                audiences react in real-time, and every set is unforgettable.
            </p>
            <div class="hero-actions">
                <button class="btn-premium" @onclick="EnterShowroom">
                    Enter Showroom
                </button>
                <button class="btn-premium btn-ghost" @onclick="ExploreComedians">
                    Meet the Syndicate
                </button>
            </div>
        </div>

        <div class="showroom-preview">
            <div class="preview-card glass-panel" @onclick="EnterShowroom" style="cursor: pointer;">
                <div class="preview-header">
                    <span class="preview-dot amber"></span>
                    <span>On Stage Now</span>
                </div>
                <div class="preview-body">
                    <h3>Neon Mike</h3>
                    <p>“Why do cloud developers never get lost? They always follow the edge route.”</p>
                </div>
            </div>
            <div class="preview-card glass-panel" @onclick="EnterShowroom" style="cursor: pointer;">
                <div class="preview-header">
                    <span class="preview-dot violet"></span>
                    <span>Audience Vibe</span>
                </div>
                <div class="preview-body">
                    <h3>🔥 Bringing the heat</h3>
                    <p>1,247 live reactions and climbing.</p>
                </div>
            </div>
        </div>
    </main>
</div>

@code {
    private void EnterShowroom()
    {
        Nav.NavigateTo("/feed");
    }

    private void ExploreComedians()
    {
        Nav.NavigateTo("/feed");
    }
}
