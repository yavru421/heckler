@page "/"
@inject HecklerApi Api
@inject IJSRuntime JS

<div class="heckler-container">
    <header class="app-header glass-panel">
        <h2 class="neon-text">🎭 Heckler Comedian Lounge</h2>
        <p class="subtitle">Select a comedian to trigger their Durable Object AI set</p>
    </header>

    <div class="main-layout">
        <!-- Comedian Lobby (Left) -->
        <section class="catalog-panel glass-panel">
            <div class="panel-header">
                <h4>🎙️ Autonomous Comedians</h4>
            </div>
            
            <div class="comedian-list">
                @foreach (var comedian in syndicateList)
                {
                    <div class="comedian-card @(selectedComedian == comedian ? "active" : "")" @onclick="() => SelectComedian(comedian)">
                        <span class="comedian-name">🗣️ @comedian</span>
                        <button class="btn-premium" @onclick="() => CueComedian(comedian)" disabled="@isGenerating" style="margin-top: 0.5rem; width: 100%;">
                            @((isGenerating && selectedComedian == comedian) ? "Generating Set..." : "Trigger AI Set 🎭")
                        </button>
                    </div>
                }
            </div>

            <h4 style="margin-top: 1.5rem; margin-bottom: 0.5rem;">📜 Saved Jokes Catalog</h4>
            <div class="shows-list scroll-panel">
                @foreach (var joke in shows)
                {
                    <div class="show-card @(selectedShow?.Id == joke.Id ? "active" : "")" @onclick="() => SelectShow(joke)">
                        <div class="show-meta">
                            <span>@@@joke.AuthorName</span>
                            <span>@joke.Category</span>
                        </div>
                        <p class="show-text">“@joke.Text”</p>
                    </div>
                }
            </div>
        </section>

        <!-- Single Audio Player (Center) -->
        <section class="player-panel glass-panel glow-border">
            @if (selectedShow != null)
            {
                <div class="player-content">
                    <span class="now-playing-tag">NOW PLAYING</span>
                    <h3 class="author-title">@@@selectedShow.AuthorName</h3>
                    <p class="featured-joke">“@selectedShow.Text”</p>
                    
                    <div class="audio-controls">
                        @if (isPlaying)
                        {
                            <button class="btn-premium btn-danger" @onclick="StopAudio">⏹️ Pause</button>
                        }
                        else
                        {
                            <button class="btn-premium" @onclick="PlaySelectedShow">▶️ Play Audio</button>
                        }
                    </div>
                </div>
            }
            else
            {
                <div class="player-empty">
                    <div class="mic-icon">🎙️</div>
                    <h3>Select a Comedian Set</h3>
                    <p>Click a comedian on the left to trigger their AI set and listen.</p>
                </div>
            }
        </section>
    </div>
</div>

<style>
    .heckler-container {
        display: flex;
        flex-direction: column;
        gap: 1.5rem;
        width: 100%;
        max-width: 1000px;
        margin: 0 auto;
        padding: 1.5rem;
        box-sizing: border-box;
    }

    .app-header {
        text-align: center;
        padding: 1.5rem;
    }

    .app-header h2 { margin: 0; font-size: 2rem; }
    .subtitle { color: var(--text-secondary); margin: 0.5rem 0 0 0; }

    .main-layout {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 1.5rem;
    }

    .catalog-panel, .player-panel {
        padding: 1.5rem;
        display: flex;
        flex-direction: column;
    }

    .comedian-list {
        display: flex;
        flex-direction: column;
        gap: 0.8rem;
    }

    .comedian-card {
        background: rgba(255, 255, 255, 0.03);
        border: 1px solid var(--glass-border);
        border-radius: 10px;
        padding: 0.8rem;
        cursor: pointer;
    }

    .comedian-card.active {
        border-color: var(--neon-purple);
        background: rgba(157, 78, 221, 0.1);
    }

    .shows-list {
        display: flex;
        flex-direction: column;
        gap: 0.5rem;
        max-height: 250px;
        overflow-y: auto;
    }

    .show-card {
        background: rgba(0, 0, 0, 0.2);
        border: 1px solid var(--glass-border);
        border-radius: 8px;
        padding: 0.6rem;
        cursor: pointer;
        font-size: 0.85rem;
    }

    .show-card.active {
        border-color: var(--neon-purple);
    }

    .show-meta {
        display: flex;
        justify-content: space-between;
        color: var(--neon-purple);
        font-weight: bold;
        font-size: 0.75rem;
    }

    .show-text {
        margin: 0.3rem 0 0 0;
        color: var(--text-primary);
    }

    .player-panel {
        justify-content: center;
        align-items: center;
        text-align: center;
        min-height: 350px;
    }

    .now-playing-tag { font-size: 0.75rem; color: var(--neon-purple); font-weight: 700; letter-spacing: 2px; }
    .author-title { margin: 0.5rem 0; font-size: 1.5rem; }
    .featured-joke { font-size: 1.2rem; line-height: 1.5; margin: 1.5rem 0; }
    .mic-icon { font-size: 3rem; margin-bottom: 1rem; }
</style>

@code {
    private List<JokeModel> shows = new();
    private JokeModel? selectedShow = null;
    private List<string> syndicateList = new() { "NeonMike", "SpicySarah", "QuantumQuentin" };
    private string selectedComedian = "NeonMike";
    private bool isGenerating = false;
    private bool isPlaying = false;

    protected override async Task OnInitializedAsync()
    {
        await LoadShowsAsync();
    }

    private async Task LoadShowsAsync()
    {
        shows = await Api.GetFeedAsync("new", 0, null);
        if (shows.Count > 0 && selectedShow == null)
        {
            selectedShow = shows[0];
        }
        StateHasChanged();
    }

    private void SelectComedian(string comedian)
    {
        selectedComedian = comedian;
        StateHasChanged();
    }

    private void SelectShow(JokeModel joke)
    {
        selectedShow = joke;
        isPlaying = false;
        StateHasChanged();
    }

    private async Task CueComedian(string comedianName)
    {
        selectedComedian = comedianName;
        isGenerating = true;
        StateHasChanged();

        var ok = await Api.TriggerComedianAsync(comedianName);
        if (ok)
        {
            await LoadShowsAsync();
        }

        isGenerating = false;
        StateHasChanged();

        if (selectedShow != null)
        {
            await PlaySelectedShow();
        }
    }

    private async Task PlaySelectedShow()
    {
        if (selectedShow == null) return;
        await JS.InvokeVoidAsync("audioInterop.unlockAudio");
        isPlaying = true;
        StateHasChanged();

        var audioUrl = $"api/jokes/{selectedShow.Id}/audio";
        var played = await JS.InvokeAsync<bool>("audioInterop.playAudioUrl", audioUrl);

        if (!played)
        {
            await JS.InvokeAsync<bool>("audioInterop.speakText", selectedShow.Text);
        }

        isPlaying = false;
        StateHasChanged();
    }

    private void StopAudio()
    {
        isPlaying = false;
        StateHasChanged();
    }
}
