@page "/"
@inject HecklerApi Api
@inject IJSRuntime JS

<div class="heckler-container">
    <!-- Header -->
    <header class="app-header glass-panel">
        <h2 class="neon-text">🎭 Heckler Comedy Lounge</h2>
        <p class="subtitle">Fresh Stand-Up Comedy on Demand</p>
    </header>

    <div class="main-layout">
        <!-- Catalog of Comedy Shows (Left) -->
        <section class="catalog-panel glass-panel">
            <div class="panel-header">
                <h4>📜 Comedy Shows Catalog</h4>
                <button class="btn-premium" @onclick="GenerateNewShow" disabled="@isGenerating">
                    @((isGenerating) ? "Generating..." : "✨ Generate New Show")
                </button>
            </div>
            
            <div class="shows-list">
                @if (shows.Count == 0 && !isLoading)
                {
                    <div class="empty-state">No comedy shows found. Click Generate New Show!</div>
                }
                else
                {
                    @foreach (var show in shows)
                    {
                        <div class="show-card @(selectedShow?.Id == show.Id ? "active" : "")" @onclick="() => SelectShow(show)">
                            <div class="show-meta">
                                <span class="show-author">🗣️ @show.AuthorName</span>
                                <span class="show-category">@show.Category</span>
                            </div>
                            <p class="show-text">“@show.Text”</p>
                            <div class="show-badge">
                                @(show.HasAudio ? "🎙️ MP3 Audio Available" : "🤖 Fallback TTS Audio")
                            </div>
                        </div>
                    }
                }
            </div>
        </section>

        <!-- Single Audio Player (Center) -->
        <section class="player-panel glass-panel glow-border">
            <div class="spotlight"></div>
            @if (selectedShow != null)
            {
                <div class="player-content">
                    <span class="now-playing-tag">NOW PLAYING</span>
                    <h3 class="author-title">@selectedShow.AuthorName</h3>
                    <p class="featured-joke">“@selectedShow.Text”</p>
                    
                    <div class="audio-controls">
                        @if (isPlaying)
                        {
                            <button class="btn-premium btn-danger" @onclick="StopAudio">⏹️ Pause</button>
                        }
                        else
                        {
                            <button class="btn-premium" @onclick="PlaySelectedShow">▶️ Play Audio</button>
                        }
                    </div>
                </div>
            }
            else
            {
                <div class="player-empty">
                    <div class="mic-icon">🎙️</div>
                    <h3>Select a Comedy Show</h3>
                    <p>Choose a show from the catalog on the left to start playback.</p>
                </div>
            }
        </section>
    </div>
</div>

<style>
    .heckler-container {
        display: flex;
        flex-direction: column;
        gap: 1.5rem;
        width: 100%;
        max-width: 1000px;
        margin: 0 auto;
        padding: 1.5rem;
        box-sizing: border-box;
    }

    .app-header {
        text-align: center;
        padding: 1.5rem;
    }

    .app-header h2 {
        margin: 0;
        font-size: 2rem;
    }

    .subtitle {
        color: var(--text-secondary);
        margin: 0.5rem 0 0 0;
        font-size: 0.95rem;
    }

    .main-layout {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 1.5rem;
    }

    @media (max-width: 768px) {
        .main-layout {
            grid-template-columns: 1fr;
        }
    }

    .catalog-panel, .player-panel {
        padding: 1.5rem;
        display: flex;
        flex-direction: column;
    }

    .panel-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 1rem;
    }

    .panel-header h4 {
        margin: 0;
        color: var(--text-primary);
        font-size: 1.1rem;
    }

    .shows-list {
        display: flex;
        flex-direction: column;
        gap: 0.8rem;
        max-height: 500px;
        overflow-y: auto;
    }

    .show-card {
        background: rgba(255, 255, 255, 0.03);
        border: 1px solid var(--glass-border);
        border-radius: 10px;
        padding: 1rem;
        cursor: pointer;
        transition: all 0.2s ease;
    }

    .show-card:hover, .show-card.active {
        background: rgba(157, 78, 221, 0.12);
        border-color: var(--neon-purple);
    }

    .show-meta {
        display: flex;
        justify-content: space-between;
        font-size: 0.8rem;
        color: var(--neon-purple);
        font-weight: 600;
        margin-bottom: 0.4rem;
    }

    .show-text {
        font-size: 0.95rem;
        line-height: 1.4;
        margin: 0 0 0.5rem 0;
        color: var(--text-primary);
    }

    .show-badge {
        font-size: 0.75rem;
        color: var(--text-secondary);
    }

    .player-panel {
        justify-content: center;
        align-items: center;
        text-align: center;
        min-height: 350px;
        position: relative;
    }

    .now-playing-tag {
        font-size: 0.75rem;
        color: var(--neon-purple);
        letter-spacing: 2px;
        font-weight: 700;
    }

    .author-title {
        margin: 0.5rem 0;
        font-size: 1.5rem;
    }

    .featured-joke {
        font-size: 1.2rem;
        line-height: 1.5;
        margin: 1.5rem 0;
    }

    .audio-controls {
        display: flex;
        justify-content: center;
        gap: 1rem;
    }

    .btn-danger {
        background: rgba(255, 51, 102, 0.2);
        border-color: var(--neon-red);
        color: var(--neon-red);
    }

    .player-empty {
        color: var(--text-secondary);
    }

    .mic-icon {
        font-size: 3rem;
        margin-bottom: 1rem;
    }

    .empty-state {
        text-align: center;
        padding: 2rem;
        color: var(--text-secondary);
    }
</style>

@code {
    private List<JokeModel> shows = new();
    private JokeModel? selectedShow = null;
    private bool isLoading = true;
    private bool isGenerating = false;
    private bool isPlaying = false;

    protected override async Task OnInitializedAsync()
    {
        await LoadShowsAsync();
    }

    private async Task LoadShowsAsync()
    {
        isLoading = true;
        shows = await Api.GetFeedAsync("new", 0, null);
        if (shows.Count > 0 && selectedShow == null)
        {
            selectedShow = shows[0];
        }
        isLoading = false;
        StateHasChanged();
    }

    private void SelectShow(JokeModel show)
    {
        selectedShow = show;
        isPlaying = false;
        StateHasChanged();
    }

    private async Task GenerateNewShow()
    {
        isGenerating = true;
        StateHasChanged();

        var newShow = await Api.GenerateShowAsync("standup comedy");
        if (newShow != null)
        {
            shows.Insert(0, newShow);
            selectedShow = newShow;
        }

        isGenerating = false;
        StateHasChanged();
    }

    private async Task PlaySelectedShow()
    {
        if (selectedShow == null) return;
        await JS.InvokeVoidAsync("audioInterop.unlockAudio");
        isPlaying = true;
        StateHasChanged();

        // Endpoint URL for clean MP3 audio stream
        var audioUrl = $"api/jokes/{selectedShow.Id}/audio";
        var played = await JS.InvokeAsync<bool>("audioInterop.playAudioUrl", audioUrl);

        if (!played)
        {
            // Fallback to streaming /api/tts directly over HTML5 Audio
            await JS.InvokeAsync<bool>("audioInterop.speakText", selectedShow.Text);
        }

        isPlaying = false;
        StateHasChanged();
    }

    private void StopAudio()
    {
        isPlaying = false;
        StateHasChanged();
    }
}
