@page "/feed"
@implements IDisposable
@inject HecklerApi Api
@inject IdentityService Identity
@inject NavigationManager Nav
@inject IJSRuntime JS


<div class="heckler-app">
    <header class="app-header glass-panel" style="border-radius: 0 0 16px 16px; margin-bottom: 1.5rem; border-top: none;">
        <div class="logo">
            <h1>ONLINE COMEDY <span class="neon-text">CLUB</span></h1>
        </div>
        <div style="display: flex; gap: 0.5rem;">
            <button class="haptic-btn" @onclick='() => Nav.NavigateTo("/foyer")' style="padding: 0.5rem 1rem; border-radius: 8px; border: 1px solid var(--neon-red); background: transparent; color: var(--neon-red); font-family: 'Oswald', sans-serif;">🏠 Foyer</button>
            <button class="haptic-btn" @onclick='() => Nav.NavigateTo("/lineups")' style="padding: 0.5rem 1rem; border-radius: 8px; border: 1px solid var(--neon-purple); background: transparent; color: var(--neon-purple); font-family: 'Oswald', sans-serif;">📜 Playlists</button>
            <button class="haptic-btn" @onclick='() => Nav.NavigateTo("/rooms")' style="padding: 0.5rem 1rem; border-radius: 8px; border: 1px solid var(--neon-blue); background: transparent; color: var(--neon-blue); font-family: 'Oswald', sans-serif;">👥 Tables</button>
        </div>
    </header>

    <main class="stage-container" style="max-width: 800px;">
        <!-- Showroom Stage Spotlight Area -->
        <div class="glass-panel fade-in-text" style="position: relative; overflow: hidden; padding: 3rem 2rem; text-align: center; border-color: var(--neon-purple); min-height: 280px; display: flex; flex-direction: column; justify-content: center; align-items: center; margin-bottom: 2rem;">
            <div class="spotlight" style="background: radial-gradient(circle, @(isPlaying ? "rgba(157, 78, 221, 0.22)" : "rgba(255, 51, 102, 0.05)") 0%, transparent 70%);"></div>

            @if (activeJoke != null)
            {
                <div style="z-index: 1;">
                    <div style="display: flex; justify-content: center; align-items: center; gap: 0.5rem; margin-bottom: 1rem;">
                        <span @onclick="GoToComedian" style="color: var(--neon-purple); font-weight: 700; font-size: 1.1rem; cursor: pointer; text-decoration: underline;">@@@activeJoke.AuthorName</span>
                        <span style="color: var(--text-secondary); font-size: 0.7rem; text-transform: uppercase; letter-spacing: 1px; background: rgba(255,255,255,0.05); padding: 0.2rem 0.6rem; border-radius: 10px;">@activeJoke.Category</span>
                    </div>

                    <p style="font-size: 1.6rem; line-height: 1.5; color: var(--text-primary); font-weight: 300; max-width: 600px; margin: 1.5rem auto;">
                        @activeJoke.Text
                    </p>

                    @if (activeJoke.HasAudio)
                    {
                        <div style="color: var(--neon-green); font-size: 0.8rem; letter-spacing: 1px; font-weight: 600; text-transform: uppercase; margin-bottom: 1rem;">
                            🎙️ REAL VOICE RECORDING
                        </div>
                    }
                    else
                    {
                        <div style="color: var(--neon-blue); font-size: 0.8rem; letter-spacing: 1px; font-weight: 600; text-transform: uppercase; margin-bottom: 1rem;">
                            🤖 TTS COMEDIAN
                        </div>
                    }
                    
                    <div class="visualizer @(isPlaying ? "active" : "")">
                        <div class="visualizer-bar"></div>
                        <div class="visualizer-bar"></div>
                        <div class="visualizer-bar"></div>
                        <div class="visualizer-bar"></div>
                        <div class="visualizer-bar"></div>
                    </div>
                </div>
            }
            else if (aiGenerating)
            {
                <div style="z-index: 1; width: 100%; max-width: 600px;">
                    <div class="skeleton-box skeleton-title"></div>
                    <div class="skeleton-box skeleton-text"></div>
                    <div class="skeleton-box skeleton-text"></div>
                    <div class="skeleton-box skeleton-text" style="width: 80%; margin: 0 auto;"></div>
                </div>
            }
            else
            {
                <div style="z-index: 1;">
                    <div style="font-size: 4rem; margin-bottom: 1rem;">🎤</div>
                    <h2 style="margin-bottom: 0.5rem;">Take a Seat</h2>
                    <p style="color: var(--text-secondary); max-width: 400px; margin: 0 auto 1.5rem auto;">Select a set list or ask the AI house comedian to write custom jokes to start the show.</p>
                </div>
            }
        </div>

        <!-- Main Showroom Dashboard -->
        <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 1.5rem; margin-bottom: 2rem;">
            <!-- Left: Player Control Panel -->
            <div class="glass-panel" style="padding: 1.5rem;">
                <h3 style="font-size: 1rem; margin-top: 0; color: var(--text-secondary); border-bottom: 1px solid var(--surface-border); padding-bottom: 0.5rem; margin-bottom: 1rem;">🎛️ Stage Controls</h3>
                
                <div style="display: flex; flex-direction: column; gap: 1rem;">
                    <!-- Play / Pause / Skip -->
                    <div style="display: flex; gap: 0.5rem;">
                        @if (isPlaying)
                        {
                            <button class="haptic-btn" @onclick="PauseSet" style="flex: 1; padding: 0.8rem; border-radius: 8px; border: 1px solid var(--neon-red); background: rgba(255,51,102,0.15); color: var(--neon-red); font-family: 'Oswald', sans-serif;">⏸️ PAUSE</button>
                        }
                        else
                        {
                            <button class="haptic-btn" @onclick="PlaySet" disabled="@(jokeQueue.Count == 0 && string.IsNullOrEmpty(aiSetText))" style="flex: 1; padding: 0.8rem; border-radius: 8px; border: 1px solid var(--neon-green); background: rgba(0,255,136,0.15); color: var(--neon-green); font-family: 'Oswald', sans-serif;">▶️ PLAY SET</button>
                        }
                        <button class="haptic-btn" @onclick="NextJoke" disabled="@(jokeQueue.Count <= 1 && string.IsNullOrEmpty(aiSetText))" style="padding: 0.8rem 1.2rem; border-radius: 8px; border: 1px solid var(--surface-border); background: transparent; color: white;">⏭️</button>
                    </div>

                    <!-- TTS Speed Control -->
                    <div>
                        <div style="display: flex; justify-content: space-between; font-size: 0.75rem; color: var(--text-secondary); margin-bottom: 0.25rem;">
                            <span>Delivery Pace (Speed)</span>
                            <span>@deliveryRate.ToString("F1")x</span>
                        </div>
                        <input type="range" min="0.6" max="1.6" step="0.1" @bind="deliveryRate" style="width: 100%; accent-color: var(--neon-purple);" />
                    </div>

                    <!-- Queue Status -->
                    <div style="font-size: 0.8rem; color: var(--text-secondary); background: rgba(0,0,0,0.3); padding: 0.6rem 1rem; border-radius: 8px; border: 1px solid var(--surface-border);">
                        📍 Currently: <strong>@(activeJokeIndex + 1) / @jokeQueue.Count</strong> in lineup
                    </div>
                </div>
            </div>

            <!-- Right: Select Set / Book Show -->
            <div class="glass-panel" style="padding: 1.5rem;">
                <h3 style="font-size: 1rem; margin-top: 0; color: var(--text-secondary); border-bottom: 1px solid var(--surface-border); padding-bottom: 0.5rem; margin-bottom: 1rem;">🎭 Book a Show</h3>
                
                <div style="display: flex; flex-direction: column; gap: 0.75rem;">
                    <!-- Dynamic DB Sets -->
                    <button class="haptic-btn" @onclick='() => LoadCategorySet("observational")' style="padding: 0.6rem; border-radius: 8px; border: 1px solid var(--surface-border); background: rgba(255,255,255,0.03); color: white; text-align: left; font-size: 0.9rem;">👀 Observational Set (From DB)</button>
                    <button class="haptic-btn" @onclick='() => LoadCategorySet("dark")' style="padding: 0.6rem; border-radius: 8px; border: 1px solid var(--surface-border); background: rgba(255,255,255,0.03); color: white; text-align: left; font-size: 0.9rem;">🌑 Dark Comedy Set (From DB)</button>
                    
                    <!-- AI Comedian Setup -->
                    <div style="border-top: 1px solid var(--surface-border); padding-top: 0.75rem; margin-top: 0.25rem;">
                        <label style="display: block; font-size: 0.75rem; color: var(--text-secondary); margin-bottom: 0.25rem;">AI Comedian Prompt</label>
                        <div style="display: flex; gap: 0.5rem;">
                            <input type="text" @bind="aiTheme" placeholder="e.g. airport security" style="flex: 1; padding: 0.5rem; border-radius: 6px; border: 1px solid var(--surface-border); background: black; color: white; font-size: 0.85rem;" />
                            <button class="haptic-btn" @onclick="GenerateAiSet" style="padding: 0.5rem 1rem; border-radius: 6px; border: none; background: var(--neon-purple); color: white; font-family: 'Oswald', sans-serif; font-size: 0.8rem; white-space: nowrap;">GENERATE 🤖</button>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Crowd Soundboard Interaction (Replaced Kills/Bombs Buttons) -->
        <div class="glass-panel" style="padding: 1.5rem; text-align: center;">
            <h3 style="font-size: 1rem; margin-top: 0; color: var(--text-secondary); margin-bottom: 1rem;">🔊 Crowd Ambient Reactions</h3>
            <div style="display: flex; justify-content: center; gap: 1rem;">
                <button class="haptic-btn reaction-burst" @onclick='() => TriggerReaction("laugh")' style="padding: 0.8rem 1.5rem; border-radius: 30px; border: 1px solid var(--neon-green); background: rgba(0,255,136,0.05); color: var(--neon-green); font-family: 'Oswald', sans-serif; font-size: 1rem;">😂 LAUGH</button>
                <button class="haptic-btn reaction-burst" @onclick='() => TriggerReaction("clap")' style="padding: 0.8rem 1.5rem; border-radius: 30px; border: 1px solid var(--neon-blue); background: rgba(0,240,255,0.05); color: var(--neon-blue); font-family: 'Oswald', sans-serif; font-size: 1rem;">👏 CLAP</button>
                <button class="haptic-btn reaction-burst" @onclick='() => TriggerReaction("boo")' style="padding: 0.8rem 1.5rem; border-radius: 30px; border: 1px solid var(--neon-red); background: rgba(255,51,102,0.05); color: var(--neon-red); font-family: 'Oswald', sans-serif; font-size: 1rem;">🍅 BOO</button>
            </div>
            <p style="font-size: 0.75rem; color: var(--text-secondary); margin-top: 0.75rem; margin-bottom: 0;">Interact synchronously to trigger local synthesizer sound effects.</p>
        </div>

        <!-- Audience Chat Section -->
        <div class="glass-panel" style="padding: 1.5rem; margin-top: 2rem;">
            <h3 style="font-size: 1rem; margin-top: 0; color: var(--text-secondary); border-bottom: 1px solid var(--surface-border); padding-bottom: 0.5rem; margin-bottom: 1rem;">💬 Audience Chat Feedback</h3>
            
            <div style="max-height: 200px; overflow-y: auto; display: flex; flex-direction: column; gap: 0.5rem; margin-bottom: 1rem; text-align: left; padding: 0.5rem; background: rgba(0,0,0,0.2); border-radius: 8px;">
                @if (chatMessages.Count == 0)
                {
                    <p style="color: var(--text-secondary); font-size: 0.85rem; margin: 0; text-align: center;">No chatter in the club yet. Start the banter!</p>
                }
                else
                {
                    @foreach (var msg in chatMessages)
                    {
                        <div style="font-size: 0.85rem; border-bottom: 1px solid rgba(255,255,255,0.05); padding-bottom: 0.25rem;">
                            <strong style="color: var(--neon-blue);">@msg.Username</strong>: 
                            <span style="color: var(--text-primary);">@msg.Message</span>
                            <span style="font-size: 0.7rem; color: var(--text-secondary); float: right;">@msg.CreatedAt.ToLocalTime().ToString("t")</span>
                        </div>
                    }
                }
            </div>

            <div style="display: flex; gap: 0.5rem;">
                <input type="text" @bind="chatUsername" placeholder="Nickname..." style="width: 120px; padding: 0.5rem; border-radius: 6px; border: 1px solid var(--surface-border); background: black; color: white; font-size: 0.85rem;" />
                <input type="text" @bind="newChatMessage" @onkeyup="HandleChatKey" placeholder="Type feedback banter..." style="flex: 1; padding: 0.5rem; border-radius: 6px; border: 1px solid var(--surface-border); background: black; color: white; font-size: 0.85rem;" />
                <button class="haptic-btn" @onclick="SendChat" style="padding: 0.5rem 1.2rem; border-radius: 6px; border: none; background: var(--neon-blue); color: white; font-family: 'Oswald', sans-serif; font-size: 0.85rem;">SEND 📣</button>
            </div>
        </div>
    </main>
</div>

@code {
    [Parameter]
    [SupplyParameterFromQuery(Name = "lineup")]
    public string? LineupQueryId { get; set; }

    private List<JokeModel> jokeQueue = new();
    private JokeModel? activeJoke = null;
    private int activeJokeIndex = 0;
    private bool isPlaying = false;
    private float deliveryRate = 1.0f;
    private string aiTheme = "";
    private bool aiGenerating = false;
    private string aiSetText = "";

    protected override async Task OnParametersSetAsync()
    {
        if (!string.IsNullOrEmpty(LineupQueryId))
        {
            var detail = await Api.GetLineupByIdAsync(LineupQueryId);
            if (detail != null && detail.Jokes.Count > 0)
            {
                jokeQueue = detail.Jokes;
                activeJokeIndex = 0;
                activeJoke = jokeQueue[0];
                StateHasChanged();
                return;
            }
        }
        await LoadCategorySet("observational");
    }

    private async Task LoadCategorySet(string category)
    {
        await CancelPlayback();
        aiSetText = "";
        
        jokeQueue = await Api.GetFeedAsync("random", 0, category);
        
        activeJokeIndex = 0;
        if (jokeQueue.Count > 0)
        {
            activeJoke = jokeQueue[0];
        }
        else
        {
            activeJoke = null;
        }
        StateHasChanged();
    }

    public async Task LoadLineupSet(List<JokeModel> jokes)
    {
        await CancelPlayback();
        aiSetText = "";
        
        jokeQueue = jokes;
        activeJokeIndex = 0;
        if (jokeQueue.Count > 0)
        {
            activeJoke = jokeQueue[0];
        }
        else
        {
            activeJoke = null;
        }
        StateHasChanged();
        await PlaySet();
    }

    private async Task PlaySet()
    {
        if (activeJoke == null && string.IsNullOrEmpty(aiSetText)) return;
        isPlaying = true;
        StateHasChanged();

        if (!string.IsNullOrEmpty(aiSetText))
        {
            // Playing the AI set
            await JS.InvokeVoidAsync("audioInterop.speakText", aiSetText, deliveryRate);
            isPlaying = false;
            aiSetText = "";
            activeJoke = null;
            StateHasChanged();
            return;
        }

        // Loop through queue
        while (isPlaying && activeJokeIndex < jokeQueue.Count)
        {
            activeJoke = jokeQueue[activeJokeIndex];
            StateHasChanged();

            if (activeJoke.HasAudio)
            {
                // Play recorded audio
                var baseAddr = (Api.GetType().GetField("_http", System.Reflection.BindingFlags.NonPublic | System.Reflection.BindingFlags.Instance)?.GetValue(Api) is HttpClient client) ? client.BaseAddress?.ToString() : "";
                var audioUrl = $"{baseAddr}api/jokes/{activeJoke.Id}/audio";
                await JS.InvokeVoidAsync("audioInterop.playAudioUrl", audioUrl);
            }
            else
            {
                // Play TTS
                await JS.InvokeVoidAsync("audioInterop.speakText", activeJoke.Text, deliveryRate);
            }

            if (!isPlaying) break;

            activeJokeIndex++;
            if (activeJokeIndex >= jokeQueue.Count)
            {
                isPlaying = false;
                activeJoke = null;
                break;
            }
        }
        StateHasChanged();
    }

    private async Task PauseSet()
    {
        isPlaying = false;
        await JS.InvokeVoidAsync("audioInterop.cancelSpeech");
        StateHasChanged();
    }

    private async Task CancelPlayback()
    {
        isPlaying = false;
        await JS.InvokeVoidAsync("audioInterop.cancelSpeech");
    }

    private async Task NextJoke()
    {
        if (!string.IsNullOrEmpty(aiSetText))
        {
            await CancelPlayback();
            aiSetText = "";
            activeJoke = null;
            StateHasChanged();
            return;
        }

        await CancelPlayback();
        if (activeJokeIndex < jokeQueue.Count - 1)
        {
            activeJokeIndex++;
            activeJoke = jokeQueue[activeJokeIndex];
            StateHasChanged();
            await PlaySet();
        }
    }

    private async Task GenerateAiSet()
    {
        if (string.IsNullOrWhiteSpace(aiTheme)) return;
        
        await CancelPlayback();
        activeJoke = null;
        aiGenerating = true;
        StateHasChanged();

        aiSetText = await Api.GenerateAiSetAsync(aiTheme);
        aiGenerating = false;
        
        // Setup AI Joke display
        activeJoke = new JokeModel
        {
            AuthorName = "AIHouseComedian",
            Category = "AI Standup",
            Text = aiSetText.Replace("[PAUSE]", " ... ")
        };

        StateHasChanged();
        await PlaySet();
    }

    private void TriggerReaction(string type)
    {
        _ = JS.InvokeVoidAsync("audioInterop.playSynthSound", type);
    }

    private void GoToComedian()
    {
        if (activeJoke != null && !activeJoke.AuthorName.Equals("AIHouseComedian"))
        {
            _ = CancelPlayback();
            Nav.NavigateTo($"/comedian/{activeJoke.AuthorName}");
        }
    }

    private List<ChatMessageModel> chatMessages = new();
    private string chatUsername = "AudienceMember";
    private string newChatMessage = "";
    private System.Threading.Timer? chatPollTimer;

    protected override async Task OnInitializedAsync()
    {
        var storedUsername = await Identity.GetUsernameAsync();
        if (!string.IsNullOrEmpty(storedUsername))
        {
            chatUsername = storedUsername;
        }


        chatPollTimer = new System.Threading.Timer(async _ =>
        {
            await InvokeAsync(async () =>
            {
                chatMessages = await Api.GetChatMessagesAsync();
                StateHasChanged();
            });
        }, null, 0, 5000);
    }

    private async Task SendChat()
    {
        if (string.IsNullOrWhiteSpace(newChatMessage)) return;
        var sent = await Api.SendChatMessageAsync(chatUsername, newChatMessage);
        if (sent)
        {
            newChatMessage = "";
            chatMessages = await Api.GetChatMessagesAsync();
            StateHasChanged();
        }
    }

    private async Task HandleChatKey(Microsoft.AspNetCore.Components.Web.KeyboardEventArgs e)
    {
        if (e.Key == "Enter")
        {
            await SendChat();
        }
    }

    public void Dispose()
    {
        chatPollTimer?.Dispose();
    }
}
