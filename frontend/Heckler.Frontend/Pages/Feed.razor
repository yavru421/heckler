@page "/feed"
@implements IDisposable
@inject HecklerApi Api
@inject IdentityService Identity
@inject NavigationManager Nav
@inject IJSRuntime JS

<div class="app-shell showroom-grid">
    <!-- COLUMN 1: Comedian Syndicate Sidebar -->
    <aside class="glass-panel scroll-panel" style="padding: 1.25rem; display: flex; flex-direction: column; gap: 1rem; border-color: rgba(139, 92, 246, 0.2);">
        <h3 style="font-size: 1rem; margin-top: 0; color: var(--accent-violet); border-bottom: 1px solid var(--glass-border); padding-bottom: 0.5rem; display: flex; align-items: center; gap: 0.5rem;">
            🤖 Comedian Syndicate
        </h3>
        
        <div style="display: flex; flex-direction: column; gap: 0.75rem; flex: 1;">
            @foreach (var comedian in syndicateList)
            {
                <div class="comedian-card @(selectedComedian == comedian ? "active" : "")" @onclick="() => SelectComedian(comedian)">
                    <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 0.25rem;">
                        <strong style="color: var(--text-primary);">@@@comedian</strong>
                        <span class="live-pulse" style="margin: 0; width: 8px; height: 8px; background-color: var(--neon-green); box-shadow: 0 0 6px var(--neon-green);"></span>
                    </div>
                    <div style="font-size: 0.75rem; color: var(--text-secondary);">Autonomous Durable Object</div>
                    
                    @if (selectedComedian == comedian)
                    {
                        <button class="btn-premium" @onclick="() => CueComedian(comedian)" @onclick:stopPropagation="true" style="padding: 0.4rem 0.8rem; font-size: 0.75rem; margin-top: 0.5rem; width: 100%; border-radius: 8px;">
                            Cue Standup Set 🎭
                        </button>
                    }
                </div>
            }
        </div>

        <div class="glass-panel" style="padding: 0.75rem; font-size: 0.75rem; color: var(--text-secondary); background: rgba(0,0,0,0.25);">
            💡 Durable Object instances run independently on the edge with SQLite persistent state.
        </div>
    </aside>

    <!-- COLUMN 2: Showroom Stage -->
    <main style="display: flex; flex-direction: column; gap: 1.25rem;">
        <!-- Stage spotlight player -->
        <section class="glass-panel glow-border" style="position: relative; overflow: hidden; padding: 3.5rem 2rem; text-align: center; min-height: 300px; display: flex; flex-direction: column; justify-content: center; align-items: center; flex: 1;">
            <div class="spotlight" style="background: radial-gradient(circle, @(isPlaying ? "rgba(139, 92, 246, 0.16)" : "rgba(255, 179, 71, 0.05)") 0%, transparent 70%);"></div>

            @if (activeJoke != null)
            {
                <div style="z-index: 1;">
                    <div style="display: flex; justify-content: center; align-items: center; gap: 0.5rem; margin-bottom: 1.5rem;">
                        <span @onclick="GoToComedian" style="color: var(--accent-violet); font-weight: 700; font-size: 1.2rem; cursor: pointer; text-decoration: underline; text-shadow: 0 0 12px rgba(139, 92, 246, 0.3);">@@@activeJoke.AuthorName</span>
                        <span style="color: var(--text-secondary); font-size: 0.7rem; text-transform: uppercase; letter-spacing: 1px; background: rgba(255,255,255,0.05); padding: 0.25rem 0.75rem; border-radius: 12px; border: 1px solid var(--glass-border);">@activeJoke.Category</span>
                    </div>

                    <p style="font-size: 1.8rem; line-height: 1.55; color: var(--text-primary); font-weight: 300; max-width: 620px; margin: 1.5rem auto; text-shadow: 0 2px 8px rgba(0,0,0,0.5);">
                        “@activeJoke.Text”
                    </p>

                    @if (activeJoke.HasAudio)
                    {
                        <div style="color: var(--neon-green); font-size: 0.8rem; letter-spacing: 1.5px; font-weight: 700; text-transform: uppercase; margin-bottom: 1.25rem; text-shadow: 0 0 8px rgba(0,255,136,0.3);">
                            🎙️ Edge-Synthesized Voice Audio
                        </div>
                    }
                    else
                    {
                        <div style="color: var(--accent-amber); font-size: 0.8rem; letter-spacing: 1.5px; font-weight: 700; text-transform: uppercase; margin-bottom: 1.25rem; text-shadow: 0 0 8px rgba(255,179,71,0.3);">
                            🤖 TTS Default Synthesizer
                        </div>
                    }
                    
                    <div class="visualizer @(isPlaying ? "active" : "")" style="margin-top: 1rem;">
                        <div class="visualizer-bar"></div>
                        <div class="visualizer-bar"></div>
                        <div class="visualizer-bar"></div>
                        <div class="visualizer-bar"></div>
                        <div class="visualizer-bar"></div>
                    </div>
                </div>
            }
            else if (aiGenerating)
            {
                <div style="z-index: 1; width: 100%; max-width: 500px;">
                    <div class="skeleton-box skeleton-title" style="background: rgba(255,255,255,0.05); margin-bottom: 1rem;"></div>
                    <div class="skeleton-box skeleton-text" style="background: rgba(255,255,255,0.05); width: 100%;"></div>
                    <div class="skeleton-box skeleton-text" style="background: rgba(255,255,255,0.05); width: 85%; margin: 0.5rem auto;"></div>
                </div>
            }
            else
            {
                <div style="z-index: 1;">
                    <div style="font-size: 4.5rem; margin-bottom: 1rem; filter: drop-shadow(0 0 16px rgba(255, 179, 71, 0.4));">🎙️</div>
                    <h2 class="neon-text" style="margin-bottom: 0.5rem; font-size: 2rem;">Take a Seat</h2>
                    <p style="color: var(--text-secondary); max-width: 440px; margin: 0 auto 1.5rem auto; font-size: 0.95rem;">Select a set playlist, cue an autonomous comedian, or ask the AI writer to generate customized jokes.</p>
                </div>
            }
        </section>

        <!-- Player controls and options -->
        <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 1.25rem;">
            <!-- Left: Playback Dashboard -->
            <section class="glass-panel" style="padding: 1.25rem;">
                <h3 style="font-size: 0.9rem; margin-top: 0; color: var(--text-secondary); border-bottom: 1px solid var(--glass-border); padding-bottom: 0.5rem; margin-bottom: 1rem;">
                    🎛️ Stage Manager
                </h3>
                <div style="display: flex; flex-direction: column; gap: 0.85rem;">
                    <div style="display: flex; gap: 0.5rem;">
                        @if (isPlaying)
                        {
                            <button class="btn-premium" @onclick="PauseSet" style="flex: 1; background: rgba(239, 68, 68, 0.15); border: 1px solid var(--danger); color: var(--danger); box-shadow: none;">
                                ⏸️ PAUSE SET
                            </button>
                        }
                        else
                        {
                            <button class="btn-premium" @onclick="PlaySet" disabled="@(jokeQueue.Count == 0 && string.IsNullOrEmpty(aiSetText))" style="flex: 1;">
                                ▶️ PLAY SET
                            </button>
                        }
                        <button class="btn-premium btn-ghost" @onclick="NextJoke" disabled="@(jokeQueue.Count <= 1 && string.IsNullOrEmpty(aiSetText))" style="padding: 0.75rem 1.25rem;">
                            ⏭️
                        </button>
                    </div>

                    <div>
                        <div style="display: flex; justify-content: space-between; font-size: 0.75rem; color: var(--text-secondary); margin-bottom: 0.25rem;">
                            <span>Joke Delivery Pace</span>
                            <span>@deliveryRate.ToString("F1")x</span>
                        </div>
                        <input type="range" min="0.6" max="1.6" step="0.1" @bind="deliveryRate" style="width: 100%; accent-color: var(--accent-violet);" />
                    </div>

                    <div style="font-size: 0.8rem; color: var(--text-secondary); background: rgba(0,0,0,0.2); padding: 0.5rem 0.75rem; border-radius: 8px; border: 1px solid var(--glass-border); display: flex; justify-content: space-between;">
                        <span>Lineup Position:</span>
                        <strong>@(activeJokeIndex + 1) / @jokeQueue.Count</strong>
                    </div>
                </div>
            </section>

            <!-- Right: Playlists & AI Writer -->
            <section class="glass-panel" style="padding: 1.25rem;">
                <h3 style="font-size: 0.9rem; margin-top: 0; color: var(--text-secondary); border-bottom: 1px solid var(--glass-border); padding-bottom: 0.5rem; margin-bottom: 1rem;">
                    ✍️ AI Comedy Writer
                </h3>
                <div style="display: flex; flex-direction: column; gap: 0.75rem;">
                    <div style="display: flex; gap: 0.5rem;">
                        <button class="btn-premium btn-ghost" @onclick='() => LoadCategorySet("observational")' style="flex: 1; padding: 0.5rem; font-size: 0.8rem;">👀 Obs. Set</button>
                        <button class="btn-premium btn-ghost" @onclick='() => LoadCategorySet("dark")' style="flex: 1; padding: 0.5rem; font-size: 0.8rem;">🌑 Dark Set</button>
                    </div>

                    <div style="border-top: 1px solid var(--glass-border); padding-top: 0.5rem;">
                        <label style="display: block; font-size: 0.75rem; color: var(--text-secondary); margin-bottom: 0.25rem;">Custom Set Theme</label>
                        <div style="display: flex; gap: 0.5rem;">
                            <input type="text" @bind="aiTheme" class="form-input" placeholder="e.g. airport security" style="font-size: 0.8rem; padding: 0.5rem 1rem; border-radius: 8px;" />
                            <button class="btn-premium" @onclick="GenerateAiSet" style="padding: 0.5rem 1rem; font-size: 0.8rem; border-radius: 8px;">Write 🤖</button>
                        </div>
                    </div>
                </div>
            </section>
        </div>
    </main>

    <!-- COLUMN 3: Audience Bar -->
    <aside class="glass-panel scroll-panel" style="padding: 1.25rem; display: flex; flex-direction: column; gap: 1rem; border-color: rgba(255, 179, 71, 0.2);">
        <h3 style="font-size: 1rem; margin-top: 0; color: var(--accent-amber); border-bottom: 1px solid var(--glass-border); padding-bottom: 0.5rem; display: flex; align-items: center; gap: 0.5rem;">
            💬 Audience Club Chat
        </h3>

        <!-- Chat messages view -->
        <div style="flex: 1; overflow-y: auto; display: flex; flex-direction: column; gap: 0.5rem; padding: 0.25rem; max-height: 380px;" class="scroll-panel">
            @if (chatMessages.Count == 0)
            {
                <div style="color: var(--text-secondary); font-size: 0.85rem; padding: 2rem 0; text-align: center;">
                    Bar is quiet. Write some feedback banter!
                </div>
            }
            else
            {
                @foreach (var msg in chatMessages)
                {
                    <div class="chat-message">
                        <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 0.2rem;">
                            <span class="chat-username">@msg.Username</span>
                            <span class="chat-meta">@msg.CreatedAt.ToLocalTime().ToString("t")</span>
                        </div>
                        <div style="color: var(--text-primary); font-size: 0.85rem;">@msg.Message</div>
                    </div>
                }
            }
        </div>

        <!-- Reactions soundboard -->
        <section style="border-top: 1px solid var(--glass-border); padding-top: 0.75rem;">
            <h4 style="font-size: 0.8rem; margin: 0 0 0.5rem 0; color: var(--text-secondary); text-transform: uppercase; letter-spacing: 1px;">Crowd Reaction Soundboard</h4>
            <div style="display: flex; gap: 0.4rem;">
                <button class="btn-premium btn-ghost reaction-burst" @onclick='() => TriggerReaction("laugh")' style="flex: 1; padding: 0.5rem 0; font-size: 0.75rem; border-color: var(--neon-green); color: var(--neon-green);">😂 Laugh</button>
                <button class="btn-premium btn-ghost reaction-burst" @onclick='() => TriggerReaction("clap")' style="flex: 1; padding: 0.5rem 0; font-size: 0.75rem; border-color: var(--neon-blue); color: var(--neon-blue);">👏 Clap</button>
                <button class="btn-premium btn-ghost reaction-burst" @onclick='() => TriggerReaction("boo")' style="flex: 1; padding: 0.5rem 0; font-size: 0.75rem; border-color: var(--neon-red); color: var(--neon-red);">🍅 Boo</button>
            </div>
        </section>

        <!-- Send message form -->
        <div style="display: flex; flex-direction: column; gap: 0.5rem; border-top: 1px solid var(--glass-border); padding-top: 0.75rem;">
            <input type="text" @bind="chatUsername" class="form-input" placeholder="Nickname..." style="font-size: 0.8rem; padding: 0.4rem 0.8rem; border-radius: 8px;" />
            <div style="display: flex; gap: 0.4rem;">
                <input type="text" @bind="newChatMessage" @onkeyup="HandleChatKey" class="form-input" placeholder="Feedback banter..." style="font-size: 0.8rem; padding: 0.4rem 0.8rem; border-radius: 8px; flex: 1;" />
                <button class="btn-premium" @onclick="SendChat" style="padding: 0.4rem 0.8rem; font-size: 0.8rem; border-radius: 8px;">Send</button>
            </div>
        </div>
    </aside>
</div>

@code {
    [Parameter]
    [SupplyParameterFromQuery(Name = "lineup")]
    public string? LineupQueryId { get; set; }

    private List<JokeModel> jokeQueue = new();
    private JokeModel? activeJoke = null;
    private int activeJokeIndex = 0;
    private bool isPlaying = false;
    private float deliveryRate = 1.0f;
    private string aiTheme = "";
    private bool aiGenerating = false;
    private string aiSetText = "";

    // Syndicate variables
    private List<string> syndicateList = new() { "NeonMike", "SpicySarah", "QuantumQuentin" };
    private string selectedComedian = "NeonMike";

    protected override async Task OnParametersSetAsync()
    {
        if (!string.IsNullOrEmpty(LineupQueryId))
        {
            var detail = await Api.GetLineupByIdAsync(LineupQueryId);
            if (detail != null && detail.Jokes.Count > 0)
            {
                jokeQueue = detail.Jokes;
                activeJokeIndex = 0;
                activeJoke = jokeQueue[0];
                StateHasChanged();
                return;
            }
        }
        await LoadCategorySet("observational");
    }

    private void SelectComedian(string comedian)
    {
        selectedComedian = comedian;
        StateHasChanged();
    }

    private async Task CueComedian(string comedianName)
    {
        await CancelPlayback();
        aiGenerating = true;
        StateHasChanged();

        // Trigger the ComedianDO to generate and save a joke with TTS audio
        var triggered = await Api.TriggerComedianAsync(comedianName);
        if (triggered)
        {
            // Load latest jokes from this comedian
            jokeQueue = await Api.GetFeedAsync("new", 0, null);
            // Filter queue to this comedian
            jokeQueue = jokeQueue.Where(j => j.AuthorName.Equals(comedianName, StringComparison.OrdinalIgnoreCase)).ToList();

            if (jokeQueue.Count > 0)
            {
                activeJokeIndex = 0;
                activeJoke = jokeQueue[0];
            }
        }

        aiGenerating = false;
        StateHasChanged();
        if (activeJoke != null)
        {
            await PlaySet();
        }
    }

    private async Task LoadCategorySet(string category)
    {
        await CancelPlayback();
        aiSetText = "";
        
        jokeQueue = await Api.GetFeedAsync("random", 0, category);
        
        activeJokeIndex = 0;
        if (jokeQueue.Count > 0)
        {
            activeJoke = jokeQueue[0];
        }
        else
        {
            activeJoke = null;
        }
        StateHasChanged();
    }

    public async Task LoadLineupSet(List<JokeModel> jokes)
    {
        await CancelPlayback();
        aiSetText = "";
        
        jokeQueue = jokes;
        activeJokeIndex = 0;
        if (jokeQueue.Count > 0)
        {
            activeJoke = jokeQueue[0];
        }
        else
        {
            activeJoke = null;
        }
        StateHasChanged();
        await PlaySet();
    }

    private async Task PlaySet()
    {
        if (activeJoke == null && string.IsNullOrEmpty(aiSetText)) return;
        isPlaying = true;
        StateHasChanged();

        if (!string.IsNullOrEmpty(aiSetText))
        {
            await JS.InvokeVoidAsync("audioInterop.speakText", aiSetText, deliveryRate);
            isPlaying = false;
            aiSetText = "";
            activeJoke = null;
            StateHasChanged();
            return;
        }

        while (isPlaying && activeJokeIndex < jokeQueue.Count)
        {
            activeJoke = jokeQueue[activeJokeIndex];
            StateHasChanged();

            if (activeJoke.HasAudio)
            {
                var baseAddr = (Api.GetType().GetField("_http", System.Reflection.BindingFlags.NonPublic | System.Reflection.BindingFlags.Instance)?.GetValue(Api) is HttpClient client) ? client.BaseAddress?.ToString() : "";
                var audioUrl = $"{baseAddr}api/jokes/{activeJoke.Id}/audio";
                await JS.InvokeVoidAsync("audioInterop.playAudioUrl", audioUrl);
            }
            else
            {
                await JS.InvokeVoidAsync("audioInterop.speakText", activeJoke.Text, deliveryRate);
            }

            if (!isPlaying) break;

            activeJokeIndex++;
            if (activeJokeIndex >= jokeQueue.Count)
            {
                isPlaying = false;
                activeJoke = null;
                break;
            }
        }
        StateHasChanged();
    }

    private async Task PauseSet()
    {
        isPlaying = false;
        await JS.InvokeVoidAsync("audioInterop.cancelSpeech");
        StateHasChanged();
    }

    private async Task CancelPlayback()
    {
        isPlaying = false;
        await JS.InvokeVoidAsync("audioInterop.cancelSpeech");
    }

    private async Task NextJoke()
    {
        if (!string.IsNullOrEmpty(aiSetText))
        {
            await CancelPlayback();
            aiSetText = "";
            activeJoke = null;
            StateHasChanged();
            return;
        }

        await CancelPlayback();
        if (activeJokeIndex < jokeQueue.Count - 1)
        {
            activeJokeIndex++;
            activeJoke = jokeQueue[activeJokeIndex];
            StateHasChanged();
            await PlaySet();
        }
    }

    private async Task GenerateAiSet()
    {
        if (string.IsNullOrWhiteSpace(aiTheme)) return;
        
        await CancelPlayback();
        activeJoke = null;
        aiGenerating = true;
        StateHasChanged();

        aiSetText = await Api.GenerateAiSetAsync(aiTheme);
        aiGenerating = false;
        
        activeJoke = new JokeModel
        {
            AuthorName = "AIHouseComedian",
            Category = "AI Standup",
            Text = aiSetText.Replace("[PAUSE]", " ... ")
        };

        StateHasChanged();
        await PlaySet();
    }

    private void TriggerReaction(string type)
    {
        _ = JS.InvokeVoidAsync("audioInterop.playSynthSound", type);
    }

    private void GoToComedian()
    {
        if (activeJoke != null && !activeJoke.AuthorName.Equals("AIHouseComedian"))
        {
            _ = CancelPlayback();
            Nav.NavigateTo($"/comedian/{activeJoke.AuthorName}");
        }
    }

    private List<ChatMessageModel> chatMessages = new();
    private string chatUsername = "AudienceMember";
    private string newChatMessage = "";
    private System.Threading.Timer? chatPollTimer;

    protected override async Task OnInitializedAsync()
    {
        var storedUsername = await Identity.GetUsernameAsync();
        if (!string.IsNullOrEmpty(storedUsername))
        {
            chatUsername = storedUsername;
        }

        chatPollTimer = new System.Threading.Timer(async _ =>
        {
            await InvokeAsync(async () =>
            {
                chatMessages = await Api.GetChatMessagesAsync();
                StateHasChanged();
            });
        }, null, 0, 5000);
    }

    private async Task SendChat()
    {
        if (string.IsNullOrWhiteSpace(newChatMessage)) return;
        var sent = await Api.SendChatMessageAsync(chatUsername, newChatMessage);
        if (sent)
        {
            newChatMessage = "";
            chatMessages = await Api.GetChatMessagesAsync();
            StateHasChanged();
        }
    }

    private async Task HandleChatKey(Microsoft.AspNetCore.Components.Web.KeyboardEventArgs e)
    {
        if (e.Key == "Enter")
        {
            await SendChat();
        }
    }

    public void Dispose()
    {
        chatPollTimer?.Dispose();
    }
}
