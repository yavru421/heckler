@page "/writers"
@using Heckler.Frontend.Models
@inject JokeService JokeService

<div class="stage-container">
    <div class="stage-header">
        <h2>Stage Spotlight</h2>
        <div class="live-indicator"></div>
    </div>
    
    <div class="mode-selector glass-panel">
        <button class="mode-btn @(selectedType == "standup" ? "active" : "")" @onclick='() => SetType("standup")'>
            🎙️ Standup
        </button>
        <button class="mode-btn @(selectedType == "dictionary" ? "active" : "")" @onclick='() => SetType("dictionary")'>
            📖 Urban Dict
        </button>
        <button class="mode-btn @(selectedType == "roast" ? "active" : "")" @onclick='() => SetType("roast")'>
            🔥 Insult Roast
        </button>
    </div>

    <div class="joke-actions">
        <button class="btn-generate" @onclick="GenerateJoke" disabled="@isGenerating">
            @(isGenerating ? "Cooking... 🌶️" : $"Generate {GetFriendlyTypeName(selectedType)} 🎤")
        </button>
    </div>

    <div class="joke-feed single-spotlight">
        @if (LiveJokes == null)
        {
            <p class="loading-text">Tuning the mic... 🎤</p>
        }
        else
        {
            var unratedJokes = LiveJokes.Where(j => !RatedJokeIds.Contains(j.Id)).ToList();

            @if (unratedJokes.Count == 0)
            {
                <div class="empty-card glass-panel" style="padding: 3rem; text-align: center;">
                    <p class="empty-text">The stage is empty. Hit the button to generate a new routine bit!</p>
                </div>
            }
            else
            {
                var activeJoke = unratedJokes.FirstOrDefault(j => j.Id == activeJokeId) ?? unratedJokes.First();
                <div class="glass-panel joke-card-premium fade-in-text" style="padding: 2.5rem; text-align: center; position: relative; margin-top: 1rem; border-color: rgba(255, 255, 255, 0.1);">
                    <div style="font-size: 0.85rem; color: var(--neon-red); text-transform: uppercase; letter-spacing: 2px; margin-bottom: 1rem; font-weight: bold;">
                        @activeJoke.Premise
                    </div>
                    <p style="font-size: 1.6rem; line-height: 1.5; font-weight: 300; margin-bottom: 2rem; color: #f0f0f0;">
                        @activeJoke.Text
                    </p>
                    
                    <div style="display: flex; justify-content: center; gap: 1.5rem; margin-top: 1.5rem;">
                        <button class="btn-generate haptic-btn" @onclick='() => HandleManualRating(activeJoke.Id, true)' style="padding: 0.8rem 2rem; font-size: 1.1rem; background: var(--neon-green); color: black; border: none; font-weight: bold; border-radius: 8px; box-shadow: 0 0 10px rgba(42, 255, 95, 0.2);">
                            🔥 KILL
                        </button>
                        <button class="btn-generate haptic-btn" @onclick='() => HandleManualRating(activeJoke.Id, false)' style="padding: 0.8rem 2rem; font-size: 1.1rem; background: var(--neon-red); color: white; border: none; font-weight: bold; border-radius: 8px; box-shadow: 0 0 10px rgba(255, 42, 95, 0.2);">
                            🍅 BOMB
                        </button>
                    </div>
                </div>
            }
        }
    </div>
</div>

@code {
    private List<JokeModel>? LiveJokes { get; set; }
    private HashSet<string> RatedJokeIds { get; set; } = new();
    private string? activeJokeId = null;
    private string selectedType = "standup";
    private bool isGenerating = false;

    protected override async Task OnInitializedAsync()
    {
        await LoadJokes();
    }

    private async Task LoadJokes()
    {
        LiveJokes = await JokeService.GetActiveJokesAsync();
        StateHasChanged();
    }

    private void SetType(string type)
    {
        selectedType = type;
    }

    private string GetFriendlyTypeName(string type)
    {
        return type switch
        {
            "dictionary" => "Urban Definition",
            "roast" => "Insult Roast",
            _ => "Standup Joke"
        };
    }

    private async Task HandleVote(string jokeId)
    {
        RatedJokeIds.Add(jokeId);
        if (activeJokeId == jokeId)
        {
            activeJokeId = null; 
        }
        await LoadJokes();
    }

    private async Task HandleManualRating(string jokeId, bool isKill)
    {
        var ratingStr = isKill ? "kill" : "bomb";
        _ = JokeService.RateJokeAsync(jokeId, ratingStr);
        await HandleVote(jokeId);
    }

    private async Task GenerateJoke()
    {
        isGenerating = true;
        StateHasChanged();
        
        var newJoke = await JokeService.GenerateJokeAsync(selectedType);
        if (newJoke != null)
        {
            activeJokeId = newJoke.Id;
        }
        await LoadJokes();
        
        isGenerating = false;
        StateHasChanged();
    }
}

