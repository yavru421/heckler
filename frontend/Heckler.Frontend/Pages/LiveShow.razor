@page "/live"
@using Heckler.Frontend.Models
@using Heckler.Frontend.Services
@inject JokeService JokeService
@inject HttpClient Http
@inject IJSRuntime JSRuntime
@inject NavigationManager NavManager
@implements IDisposable

<div class="heckler-app" style="--audio-scale: calc(1 + var(--audio-level, 0));">
    <header class="app-header glass-panel" style="border-radius: 0 0 16px 16px; margin-bottom: 2rem; border-top: none;">
        <div class="logo">
            <h1>LIVE<span class="neon-text" style="color: var(--neon-red);">SHOW</span></h1>
            <div class="age-warning" style="color: var(--neon-green);">Audio First - Continuous Play</div>
        </div>
    </header>

    <main class="app-content stage-container" style="display: flex; flex-direction: column; gap: 2rem; max-width: 700px; margin: 0 auto; padding: 0 1rem;">
        
        @if (isShowOver)
        {
            <div class="glass-panel" style="padding: 3rem; text-align: center; border-color: var(--neon-green);">
                <h2 style="margin-bottom: 1rem; color: var(--neon-green);">How was the show?</h2>
                <p style="color: #aaa; margin-bottom: 2rem;">The comedian has left the stage.</p>
                <div style="margin: 2rem 0; font-size: 4rem; display: flex; justify-content: center; gap: 1rem; cursor: pointer;">
                    @for (int i = 1; i <= 5; i++)
                    {
                        var starVal = i;
                        <span @onclick="() => SetRating(starVal)" style="color: @(starRating >= starVal ? "var(--neon-green)" : "#444"); transition: color 0.3s, transform 0.2s; text-shadow: @(starRating >= starVal ? "0 0 15px var(--neon-green)" : "none");" class="star-rating">★</span>
                    }
                </div>
                <textarea @bind="userComment" placeholder="Leave a review (optional)..." class="form-control" style="width: 100%; height: 120px; padding: 1rem; border-radius: 8px; border: 1px solid #444; background: rgba(0,0,0,0.5); color: white; margin-bottom: 1.5rem; font-family: 'Inter', sans-serif;"></textarea>
                <button class="btn-generate haptic-btn" @onclick="SubmitReview" disabled="@isSubmitting" style="width: 100%; padding: 1.5rem; font-size: 1.2rem; background: var(--neon-green); color: black; border: none; font-weight: bold; text-transform: uppercase;">
                    @(isSubmitting ? "Submitting..." : "Submit Review")
                </button>
            </div>
        }
        else
        {
            <div class="glass-panel main-stage" style="padding: 3rem 2rem; text-align: center; position: relative; overflow: hidden;">
                <!-- Audio Visualizer Spotlight -->
                <div class="spotlight" style="transform: scale(var(--audio-scale));"></div>

                @if (!showStarted)
                {
                    <div style="padding: 3rem 0; position: relative; z-index: 2;">
                        <h2 style="margin-bottom: 1rem; font-size: 2.5rem;">Ready for the show?</h2>
                        <p style="color: #888; margin-bottom: 3rem; font-size: 1.1rem;">Rate the comedian's jokes in real-time to guide their set!</p>
                        <button class="btn-generate haptic-btn" @onclick="StartShow" style="padding: 1.5rem 3rem; font-size: 1.3rem; background: var(--neon-red); color: white; border: none; font-weight: bold; border-radius: 50px; box-shadow: 0 0 20px rgba(255, 42, 95, 0.4);">
                            START SHOW 🎙️
                        </button>
                    </div>
                }
                else if (activeJoke != null)
                {
                    <div style="position: relative; z-index: 2;">
                        @if (tensionScore >= 80)
                        {
                            <div style="color: var(--neon-red); font-weight: bold; font-size: 1.2rem; margin-bottom: 1rem; animation: pulse 0.8s infinite;">
                                ⚠️ COMEDIAN IS BOMBING! (TENSION HIGH)
                            </div>
                        }
                        <h3 style="margin-bottom: 1.5rem; color: var(--neon-red); font-size: 1.5rem; letter-spacing: 2px;">@activeJoke.Premise</h3>
                        <p class="fade-in-text" style="font-size: 1.8rem; margin-bottom: 2rem; line-height: 1.4; font-weight: 300;">@activeJoke.Text</p>
                        
                        @if (activeJoke.Premise != "[comeback] bomb" && !activeJoke.Premise.StartsWith("[comeback]"))
                        {
                            <div class="stage-controls" style="display: flex; justify-content: center; gap: 2rem; margin-top: 1.5rem; position: relative; z-index: 10;">
                                <button class="btn-generate haptic-btn" @onclick="() => HandleManualRating(true)" style="padding: 1rem 2rem; font-size: 1.1rem; background: var(--neon-green); color: black; border: none; font-weight: bold; border-radius: 8px; box-shadow: 0 0 10px rgba(42, 255, 95, 0.2);">
                                    🔥 KILL
                                </button>
                                <button class="btn-generate haptic-btn" @onclick="() => HandleManualRating(false)" style="padding: 1rem 2rem; font-size: 1.1rem; background: var(--neon-red); color: white; border: none; font-weight: bold; border-radius: 8px; box-shadow: 0 0 10px rgba(255, 42, 95, 0.2);">
                                    🍅 BOMB
                                </button>
                            </div>
                        }

                        @if (isListeningForLaughter)
                        {
                            <div style="margin-top: 2rem; color: var(--neon-green); font-size: 1.1rem; animation: pulse 1s infinite; font-weight: bold;">
                                🎤 Listening for your reaction...
                            </div>
                        }
                    </div>
                }
                else
                {
                    <div style="padding: 4rem 0; position: relative; z-index: 2;">
                        <div class="mic-icon" style="font-size: 4rem; margin-bottom: 1rem; animation: bounce 2s infinite;">🎙️</div>
                        <h3 class="neon-text" style="animation: pulse 1.5s infinite; font-size: 2rem;">Mic Check...</h3>
                        <p style="color: #666; margin-top: 1rem; letter-spacing: 2px; text-transform: uppercase;">(Comedian is walking to the stage)</p>
                    </div>
                }
            </div>

            <div class="glass-panel heckle-box" style="padding: 2rem; opacity: @(activeJoke == null ? "0.5" : "1"); pointer-events: @(activeJoke == null ? "none" : "all"); border-color: @(isGenerating ? "var(--neon-red)" : "var(--surface-border)"); transition: border-color 0.3s;">
                <h3 style="margin-bottom: 1.5rem; color: #fff;">Heckle the Comedian!</h3>
                <div style="display: flex; gap: 1rem;">
                    <input type="text" @bind="heckleText" placeholder="Yell something brutal..." class="form-control heckle-input" style="flex: 1; padding: 1rem; border-radius: 8px; border: 1px solid #444; background: rgba(0,0,0,0.6); color: white; font-size: 1.1rem;" />
                    <button class="btn-generate haptic-btn" @onclick="Heckle" disabled="@isGenerating" style="padding: 1rem 2rem; white-space: nowrap; background: var(--neon-red); color: white; border: none; font-weight: bold; border-radius: 8px;">
                        @(isGenerating ? "HECKLING..." : "HECKLE! 🍅")
                    </button>
                </div>
                
                <!-- Tension Meter -->
                <div style="margin-top: 2rem;">
                    <div style="display: flex; justify-content: space-between; font-size: 0.8rem; color: #888; text-transform: uppercase; margin-bottom: 0.5rem;">
                        <span>Room Energy</span>
                        <span>Tension</span>
                    </div>
                    <div class="tension-bar-container" style="width: 100%; height: 8px; background: #222; border-radius: 4px; overflow: hidden;">
                        <div class="tension-bar" style="width: @(tensionScore)%; height: 100%; background: linear-gradient(90deg, var(--neon-green), var(--neon-red)); transition: width 0.5s ease-out;"></div>
                    </div>
                </div>

                @if (playQueue.Count > 0)
                {
                    <div style="margin-top: 1.5rem; font-size: 0.85rem; color: #666; text-align: right; text-transform: uppercase; letter-spacing: 1px;">
                        Next up: @playQueue.First().Premise
                    </div>
                }
            </div>
        }
    </main>
</div>

<style>
    .spotlight {
        position: absolute;
        top: 50%;
        left: 50%;
        width: 300px;
        height: 300px;
        background: radial-gradient(circle, rgba(255, 42, 95, 0.15) 0%, transparent 70%);
        transform: translate(-50%, -50%);
        border-radius: 50%;
        z-index: 1;
        transition: transform 0.1s ease-out;
        pointer-events: none;
    }
    .fade-in-text {
        animation: fadeIn 0.5s ease-in;
    }
    .haptic-btn {
        transition: transform 0.1s, filter 0.2s;
        cursor: pointer;
    }
    .haptic-btn:active {
        transform: scale(0.95);
        filter: brightness(1.2);
    }
    .heckle-input:focus {
        border-color: var(--neon-red) !important;
        box-shadow: 0 0 15px rgba(255, 42, 95, 0.3) !important;
        outline: none;
    }
    .star-rating:hover {
        transform: scale(1.2);
    }
    @@keyframes pulse {
        0% { opacity: 1; }
        50% { opacity: 0.5; }
        100% { opacity: 1; }
    }
    @@keyframes bounce {
        0%, 100% { transform: translateY(0); }
        50% { transform: translateY(-10px); }
    }
    @@keyframes fadeIn {
        from { opacity: 0; transform: translateY(10px); }
        to { opacity: 1; transform: translateY(0); }
    }
</style>

@code {
    private JokeModel? activeJoke;
    private List<JokeModel> playQueue = new();
    private string heckleText = "";
    private bool isGenerating = false;
    
    private int jokesPlayed = 0;
    private bool isShowOver = false;
    private int starRating = 5;
    private string userComment = "";
    private bool isSubmitting = false;

    private int tensionScore = 20; // 0 to 100

    private bool showStarted = false;
    private bool isListeningForLaughter = false;
    private DotNetObjectReference<LiveShow>? objRef;

    protected override async Task OnInitializedAsync()
    {
        objRef = DotNetObjectReference.Create(this);
        // Don't start generating immediately, wait for user to click StartShow
    }
    
    public void Dispose()
    {
        objRef?.Dispose();
    }
    
    [JSInvokable]
    public async Task AudioEndedCallback()
    {
        await AudioEnded();
    }
    
    private async Task PlayJokeAudio()
    {
        if (activeJoke != null && objRef != null)
        {
            try {
                await JSRuntime.InvokeVoidAsync("window.speakJoke", activeJoke.Id, objRef);
            } catch {
                await AudioEnded();
            }
        }
    }

    private async Task StartShow()
    {
        try {
            await JSRuntime.InvokeVoidAsync("window.initTTS");
        } catch { }

        showStarted = true;
        StateHasChanged();

        await EnsureQueue();
        if (playQueue.Any())
        {
            activeJoke = playQueue.First();
            playQueue.RemoveAt(0);
            StateHasChanged();
            _ = PlayJokeAudio();
            _ = EnsureQueue();
        }
    }

    private async Task EnsureQueue()
    {
        while (playQueue.Count < 1 && jokesPlayed + playQueue.Count < 4)
        {
            isGenerating = true;
            StateHasChanged();
            var newJoke = await JokeService.GenerateJokeAsync("standup");
            if (newJoke != null)
            {
                playQueue.Add(newJoke);
                try {
                    _ = JSRuntime.InvokeVoidAsync("window.prefetchJokeAudio", newJoke.Id);
                } catch { }
            }
            else
            {
                break;
            }
            isGenerating = false;
            StateHasChanged();
        }
    }

    private async Task Heckle()
    {
        if (string.IsNullOrWhiteSpace(heckleText)) return;
        
        isGenerating = true;
        StateHasChanged();

        var newJoke = await JokeService.GenerateJokeAsync("heckle", heckleText);
        if (newJoke != null)
        {
            playQueue.Insert(0, newJoke);
            try {
                _ = JSRuntime.InvokeVoidAsync("window.prefetchJokeAudio", newJoke.Id);
            } catch { }
        }

        heckleText = "";
        isGenerating = false;
        StateHasChanged();
    }

    private async Task HandleManualRating(bool isKill)
    {
        if (activeJoke == null) return;

        try {
            await JSRuntime.InvokeVoidAsync("window.audioSentiment.interruptPlayback");
        } catch { }

        var jokeId = activeJoke.Id;
        var ratingStr = isKill ? "kill" : "bomb";

        if (isKill)
        {
            tensionScore = Math.Max(0, tensionScore - 15);
        }
        else
        {
            tensionScore = Math.Min(100, tensionScore + 20);
        }
        StateHasChanged();

        _ = JokeService.RateJokeAsync(jokeId, ratingStr);

        if (tensionScore >= 100)
        {
            isShowOver = true;
            activeJoke = null;
            StateHasChanged();
            return;
        }

        if (!isKill)
        {
            await PlayComedianComeback(jokeId);
        }
        else
        {
            jokesPlayed++;
            await AdvanceShow();
        }
    }

    private async Task PlayComedianComeback(string jokeId)
    {
        isGenerating = true;
        StateHasChanged();

        try
        {
            var comeback = await JokeService.ReactToRatingAsync(jokeId, "bomb");
            if (comeback != null)
            {
                activeJoke = comeback;
                isGenerating = false;
                StateHasChanged();

                await PlayJokeAudio();
                return;
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Comeback failed: {ex.Message}");
        }

        isGenerating = false;
        jokesPlayed++;
        await AdvanceShow();
    }

    private async Task AdvanceShow()
    {
        if (jokesPlayed >= 5)
        {
            isShowOver = true;
            activeJoke = null;
            StateHasChanged();
            return;
        }

        if (!playQueue.Any())
        {
            activeJoke = null;
            StateHasChanged();
            await EnsureQueue();
        }

        if (playQueue.Any())
        {
            activeJoke = playQueue.First();
            playQueue.RemoveAt(0);
            StateHasChanged();
            _ = PlayJokeAudio();
            _ = EnsureQueue();
        }
    }

    private async Task AudioEnded()
    {
        if (activeJoke != null)
        {
            // If we just finished playing a comeback reaction, we don't want to wait for a rating.
            // We just advance the show!
            if (activeJoke.Premise == "[comeback] bomb" || activeJoke.Premise.StartsWith("[comeback]"))
            {
                jokesPlayed++;
                await AdvanceShow();
                return;
            }

            // Otherwise, we just pause and wait for the user to rate the joke manually.
            // No automatic microphone checks or rating.
            StateHasChanged();
        }
    }

    private void SetRating(int r)
    {
        starRating = r;
    }

    private async Task SubmitReview()
    {
        isSubmitting = true;
        await JokeService.RateRoutineAsync(starRating, userComment);
        isSubmitting = false;
        NavManager.NavigateTo("/");
    }
}
