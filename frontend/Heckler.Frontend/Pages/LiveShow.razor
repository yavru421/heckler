@page "/live"
@using Heckler.Frontend.Models
@using Heckler.Frontend.Services
@inject JokeService JokeService
@inject HttpClient Http
@inject IJSRuntime JSRuntime
@inject NavigationManager NavManager
@implements IDisposable

<div class="heckler-app">
    <header class="app-header glass-panel">
        <div class="logo">
            <h1>LIVE<span class="neon-text">SHOW</span></h1>
            <div class="age-warning">Audio First - Continuous Play</div>
        </div>
    </header>

    <main class="app-content stage-container" style="display: flex; flex-direction: column; gap: 2rem; max-width: 600px; margin: 0 auto;">
        
        @if (isShowOver)
        {
            <div class="glass-panel" style="padding: 2rem; text-align: center;">
                <h2 style="margin-bottom: 0.5rem;">How was the show?</h2>
                <p style="color: #aaa; margin-bottom: 2rem;">The comedian has left the stage.</p>
                <div style="margin: 2rem 0; font-size: 3rem; display: flex; justify-content: center; gap: 1rem; cursor: pointer;">
                    @for (int i = 1; i <= 5; i++)
                    {
                        var starVal = i;
                        <span @onclick="() => SetRating(starVal)" style="color: @(starRating >= starVal ? "gold" : "#555"); transition: color 0.2s;">★</span>
                    }
                </div>
                <textarea @bind="userComment" placeholder="Leave a review (optional)..." class="form-control" style="width: 100%; height: 100px; padding: 1rem; border-radius: 8px; border: 1px solid #444; background: #222; color: white; margin-bottom: 1.5rem;"></textarea>
                <button class="btn-generate" @onclick="SubmitReview" disabled="@isSubmitting" style="width: 100%; padding: 1rem; font-size: 1.2rem;">
                    @(isSubmitting ? "Submitting..." : "Submit Review")
                </button>
            </div>
        }
        else
        {
            <div class="glass-panel" style="padding: 2rem; text-align: center;">
                @if (!showStarted)
                {
                    <div style="padding: 3rem 0;">
                        <h2 style="margin-bottom: 1rem;">Ready for the show?</h2>
                        <p style="color: #888; margin-bottom: 2rem;">We use your microphone to detect laughter and dynamically grade the comedian.</p>
                        <button class="btn-generate" @onclick="StartShow" style="padding: 1rem 2rem; font-size: 1.2rem;">Start Show (Enable Mic)</button>
                    </div>
                }
                else if (activeJoke != null)
                {
                    <h3 style="margin-bottom: 1rem; color: #ff2a5f;">@activeJoke.Premise</h3>
                    <p style="font-size: 1.3rem; margin-bottom: 1.5rem; line-height: 1.5;">@activeJoke.Text</p>
                    @if (isListeningForLaughter)
                    {
                        <div style="margin-top: 1rem; color: var(--neon-green); font-size: 0.9rem; animation: pulse 1s infinite;">
                            🎤 Listening for your reaction...
                        </div>
                    }
                }
                else
                {
                    <div style="padding: 3rem 0;">
                        <h3 class="neon-text" style="animation: pulse 1.5s infinite;">The Comedian is walking to the stage...</h3>
                        <p style="color: #666; margin-top: 1rem;">(Generating material)</p>
                    </div>
                }
            </div>

            <div class="glass-panel heckle-box" style="padding: 1.5rem; opacity: @(activeJoke == null ? "0.5" : "1"); pointer-events: @(activeJoke == null ? "none" : "all");">
                <h3 style="margin-bottom: 1rem;">Heckle the Comedian!</h3>
                <div style="display: flex; gap: 0.5rem;">
                    <input type="text" @bind="heckleText" placeholder="Yell something..." class="form-control" style="flex: 1; padding: 0.75rem; border-radius: 4px; border: 1px solid #444; background: #222; color: white; font-size: 1rem;" />
                    <button class="btn-generate" @onclick="Heckle" disabled="@isGenerating" style="padding: 0.75rem 1.5rem; white-space: nowrap;">
                        @(isGenerating ? "Heckling..." : "Heckle! 🍅")
                    </button>
                </div>
                @if (playQueue.Count > 0)
                {
                    <div style="margin-top: 1rem; font-size: 0.9rem; color: #888; text-align: right;">
                        Next up: @playQueue.First().Premise
                    </div>
                }
            </div>
        }
    </main>
</div>

<style>
    @@keyframes pulse {
        0% { opacity: 1; }
        50% { opacity: 0.5; }
        100% { opacity: 1; }
    }
</style>

@code {
    private JokeModel? activeJoke;
    private List<JokeModel> playQueue = new();
    private string heckleText = "";
    private bool isGenerating = false;
    
    private int jokesPlayed = 0;
    private bool isShowOver = false;
    private int starRating = 5;
    private string userComment = "";
    private bool isSubmitting = false;

    private bool showStarted = false;
    private bool isListeningForLaughter = false;
    private DotNetObjectReference<LiveShow>? objRef;

    protected override async Task OnInitializedAsync()
    {
        objRef = DotNetObjectReference.Create(this);
        // Don't start generating immediately, wait for user to click StartShow
    }
    
    public void Dispose()
    {
        objRef?.Dispose();
    }
    
    [JSInvokable]
    public async Task AudioEndedCallback()
    {
        await AudioEnded();
    }
    
    private async Task PlayJokeAudio()
    {
        if (activeJoke != null && objRef != null)
        {
            try {
                await JSRuntime.InvokeVoidAsync("window.speakJoke", activeJoke.Id, objRef);
            } catch {
                await AudioEnded();
            }
        }
    }

    private async Task StartShow()
    {
        try {
            await JSRuntime.InvokeVoidAsync("window.initTTS");
        } catch { }

        showStarted = true;
        StateHasChanged();
        
        try {
            _ = JSRuntime.InvokeAsync<bool>("window.audioSentiment.startListening");
        } catch { }

        await EnsureQueue();
        if (playQueue.Any())
        {
            activeJoke = playQueue.First();
            playQueue.RemoveAt(0);
            StateHasChanged();
            _ = PlayJokeAudio();
            _ = EnsureQueue();
        }
    }

    private async Task EnsureQueue()
    {
        // Keep exactly 1 joke in the chamber to ensure seamless playback, up to a max of 5 played in total
        while (playQueue.Count < 1 && jokesPlayed + playQueue.Count < 4)
        {
            isGenerating = true;
            StateHasChanged();
            var newJoke = await JokeService.GenerateJokeAsync("standup");
            if (newJoke != null)
            {
                playQueue.Add(newJoke);
                try {
                    _ = JSRuntime.InvokeVoidAsync("window.prefetchJokeAudio", newJoke.Id);
                } catch { }
            }
            isGenerating = false;
            StateHasChanged();
        }
    }

    private async Task Heckle()
    {
        if (string.IsNullOrWhiteSpace(heckleText)) return;
        
        isGenerating = true;
        StateHasChanged();

        var newJoke = await JokeService.GenerateJokeAsync("heckle", heckleText);
        if (newJoke != null)
        {
            // Insert heckle response immediately at the front of the queue
            playQueue.Insert(0, newJoke);
            try {
                _ = JSRuntime.InvokeVoidAsync("window.prefetchJokeAudio", newJoke.Id);
            } catch { }
        }

        heckleText = "";
        isGenerating = false;
        StateHasChanged();
    }

    private async Task AudioEnded()
    {
        if (activeJoke != null)
        {
            var jokeToRate = activeJoke.Id;
            isListeningForLaughter = true;
            StateHasChanged();

            bool laughed = false;
            try {
                laughed = await JSRuntime.InvokeAsync<bool>("window.audioSentiment.measureLaughter", 4000);
            } catch {
                await Task.Delay(4000); // Fallback wait
            }
            
            isListeningForLaughter = false;
            StateHasChanged();

            // Auto-rate the joke based on microphone volume
            _ = JokeService.RateJokeAsync(jokeToRate, laughed ? "kill" : "bomb");
        }

        jokesPlayed++;
        if (jokesPlayed >= 5)
        {
            isShowOver = true;
            activeJoke = null;
            StateHasChanged();
            return;
        }

        if (!playQueue.Any())
        {
            activeJoke = null;
            StateHasChanged();
            await EnsureQueue();
        }

        if (playQueue.Any())
        {
            activeJoke = playQueue.First();
            playQueue.RemoveAt(0);
            StateHasChanged();
            
            _ = PlayJokeAudio();
            
            _ = EnsureQueue();
        }
    }

    private void SetRating(int r)
    {
        starRating = r;
    }

    private async Task SubmitReview()
    {
        isSubmitting = true;
        await JokeService.RateRoutineAsync(starRating, userComment);
        isSubmitting = false;
        NavManager.NavigateTo("/");
    }
}
